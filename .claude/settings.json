{
  "clarify_prove_code": {
    "auto_merge": false,
    "language_tiers": {
      "tier1": ["python", "typescript", "javascript", "rust", "go", "java", "c", "cpp"],
      "tier2": ["csharp", "kotlin", "swift", "scala", "ruby"],
      "tier3_excluded": ["zig"]
    },
    "proof_dir": "proof",
    "spec_file": "SPEC.md",
    "proof_summary_file": "PROOF.md",
    "tools": {
      "dafny": {
        "required_for": ["prove"],
        "install_script": "scripts/install-dafny.sh",
        "verify_command": "dafny --version"
      }
    }
  }
}
